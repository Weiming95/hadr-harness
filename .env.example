# Copy this file to `.env` and fill in your key:  cp .env.example .env
# `.env` is gitignored; this template is safe to commit.

# Your OpenCode Go API key (from opencode.ai/auth → subscribe to Go → copy key).
OPENCODE_API_KEY=

# A model id — run `python3 harness.py --models` to list them.
OPENCODE_MODEL=kimi-k2.7-code

# Advanced (usually leave unset):
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
